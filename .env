# PixelWar Environment Configuration

# Database
DATABASE_URL=postgres://pixelwar:pixelwar@localhost:5432/pixelwar

# Redis
REDIS_URL=redis://127.0.0.1:6379

# NATS
NATS_URL=nats://127.0.0.1:4222

# Auth
JWT_SECRET=change-me-to-a-secure-random-string

# OpenTelemetry
OTEL_ENDPOINT=http://localhost:4317

HOST=0.0.0.0

# Service HTTP ports (health + local HTTP endpoints)
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
CANVAS_SERVICE_PORT=3002
CHAT_SERVICE_PORT=3003
VOTING_SERVICE_PORT=3004
GROUP_SERVICE_PORT=3005
SCHEDULER_SERVICE_PORT=3006

# gRPC ports (inter-service communication)
# The api-gateway connects to these as clients
AUTH_GRPC_URL=http://127.0.0.1:9001
CANVAS_GRPC_URL=http://127.0.0.1:9002
CHAT_GRPC_URL=http://127.0.0.1:9003
VOTING_GRPC_URL=http://127.0.0.1:9004
GROUP_GRPC_URL=http://127.0.0.1:9005

# Per-service GRPC_PORT env var (set per service, or override here)
# auth-service:     GRPC_PORT=9001
# canvas-service:   GRPC_PORT=9002
# chat-service:     GRPC_PORT=9003
# voting-service:   GRPC_PORT=9004
# group-service:    GRPC_PORT=9005

# Logging
RUST_LOG=info
